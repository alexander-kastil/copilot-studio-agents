{
	"mcpServers": {
		"azure-deploy": {
			"command": "npx",
			"args": [
				"-y",
				"@azure/mcp@latest",
				"server",
				"start"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"microsoft-learn": {
			"type": "http",
			"url": "https://learn.microsoft.com/api/mcp"
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"type": "stdio"
		},
		"workiq": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@microsoft/workiq",
				"mcp"
			]
		},
		"microsoft-foundry": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--prerelease=allow",
				"--from",
				"git+https://github.com/azure-ai-foundry/mcp-foundry.git",
				"--with",
				"mcp>=1.0,<2.0",
				"run-azure-ai-foundry-mcp",
				"--envFile",
				"D:/git-classes/ai-103/.claude/deploy.config"
			]
		}
	},
	"inputs": []
}